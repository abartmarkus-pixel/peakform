{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/send-daily-reminder?slot=morning",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/send-daily-reminder?slot=evening",
      "schedule": "0 15 * * *"
    }
  ]
}
